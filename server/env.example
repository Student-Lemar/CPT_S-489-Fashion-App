# Copy to `server/.env` and adjust values.
#
# Recommended local setup (matches CPT_S-489 stack):
# - Install MySQL (XAMPP/WAMP/MySQL Installer)
# - Create database: fashion_app
#
NODE_ENV=development
PORT=3000

# CORS (important if you use cookies / credentials on /api/*)
# - In development, if unset, defaults to http://localhost:$PORT and http://127.0.0.1:$PORT
# - In production (NODE_ENV=production), this MUST be set to your real site origin(s)
#   Example: CORS_ORIGINS=https://489fashion.example
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=fashion_app
DB_USER=root
DB_PASSWORD=rootpass

# Production safety: empty/blank DB_PASSWORD is rejected when NODE_ENV=production.
# If you truly need an empty password (not recommended), set:
# DB_ALLOW_EMPTY_PASSWORD=true
DB_ALLOW_EMPTY_PASSWORD=false

# Optional: set to "true" during early development ONLY
# Sequelize will auto-create/alter tables to match models.
DB_SYNC=false
